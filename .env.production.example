# ── OpenClaw Console — 私有雲部署環境變數 ───────────────────
# 複製為 .env 並填入真實值
# 啟動：docker compose up -d

# ── Database ──────────────────────────────────────────────────
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=                    # ← 設定強密碼
POSTGRES_DB=openclaw_console

# ── Backend ───────────────────────────────────────────────────
JWT_SECRET=                           # ← 32+ 字元隨機字串
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=                       # ← 64 位元 hex (openssl rand -hex 32)
CORS_ORIGIN=https://your-domain.com   # ← 你的前端網域

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://your-domain.com  # ← 同上（走 Nginx proxy）

# ── AI ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                    # ← 你的 Anthropic API Key

# ── LINE（選填，不使用 LINE 可留空）───────────────────────────
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=

# ── 快速生成安全隨機值（在終端機執行）────────────────────────
# JWT_SECRET:      openssl rand -base64 32
# ENCRYPTION_KEY:  openssl rand -hex 32
# POSTGRES_PASSWORD: openssl rand -base64 16
